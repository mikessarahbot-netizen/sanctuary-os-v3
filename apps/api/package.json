{
  "name": "@sanctuary-os/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./presenter": {
      "types": "./src/services/presenter/index.ts",
      "import": "./src/services/presenter/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration:postgres": "vitest run src/services/planning/postgresql-integration.test.ts src/services/presenter/postgresql-integration.test.ts"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.33",
    "@sanctuary-os/church-context": "workspace:*",
    "@sanctuary-os/db": "workspace:*",
    "graphql": "^16.14.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0"
  }
}
