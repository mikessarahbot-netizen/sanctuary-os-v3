{
  "name": "@sanctuary-os/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./demo": {
      "types": "./src/demo/index.ts",
      "import": "./src/demo/index.ts"
    },
    "./play": {
      "types": "./src/services/play/index.ts",
      "import": "./src/services/play/index.ts"
    },
    "./presenter": {
      "types": "./src/services/presenter/index.ts",
      "import": "./src/services/presenter/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration:postgres": "vitest run src/services/planning/postgresql-integration.test.ts src/services/presenter/postgresql-integration.test.ts src/services/charts/postgresql-integration.test.ts",
    "dev": "tsx src/demo/server.ts",
    "dev:persistent": "tsx src/demo/persistent-server.ts",
    "dev:postgres": "tsx src/demo/postgres-server.ts",
    "ai:smoke": "tsx src/demo/ai-smoke-test.ts",
    "obs:smoke": "tsx src/demo/obs-live-smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@graphql-tools/schema": "^10.0.33",
    "@sanctuary-os/church-context": "workspace:*",
    "@sanctuary-os/db": "workspace:*",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.2",
    "obs-websocket-js": "^5.0.8",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0",
    "tsx": "^4.22.4"
  }
}
